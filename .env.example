# Copy to `.env` next to this file. notify.sh sources it automatically.
# Any unset variable just causes that channel to be skipped.

# Telegram bot
TG_BOT_TOKEN=
TG_CHAT_ID=

# Slack (preferred: bot token + channel id)
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
# Or: a single incoming-webhook URL (used only if SLACK_BOT_TOKEN is empty)
SLACK_WEBHOOK_URL=

# HF Hub — required for auto-push of trained models
HF_TOKEN=
# Optional: override the user namespace (else taken from huggingface-cli whoami)
HF_USER=

# Optional: GitHub for code search inside the workflow
GITHUB_TOKEN=
